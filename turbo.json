{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["VERCEL"],
      "outputs": [".next/**", "!.next/cache/**", ".next-build/**", "!.next-build/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
