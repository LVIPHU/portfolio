{
  "arrowParens": "always",
  "semi": false,
  "trailingComma": "es5",
  "tabWidth": 2,
  "endOfLine": "auto",
  "useTabs": false,
  "singleQuote": true,
  "printWidth": 120,
  "jsxSingleQuote": true,
  "bracketSpacing": true,
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "apps/2025/**",
      "options": { "tailwindStylesheet": "./apps/2025/src/styles/main.css" }
    },
    {
      "files": "apps/2026/**",
      "options": { "tailwindStylesheet": "./apps/2026/src/app/globals.css" }
    }
  ]
}
