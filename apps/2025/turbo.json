{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "GITHUB_API_TOKEN"],
      "passThroughEnv": ["NODE_ENV", "VERCEL"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".next-build/**",
        "!.next-build/cache/**",
        "public/feed.xml",
        "public/search.json",
        "public/tags/**",
        "public/content/**"
      ]
    }
  }
}
