{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@env": ["./env.mjs"],
      "@data/*": ["./data/*"],
      "@json/*": ["./json/*"],
      "@public/*": ["./public/*"],
      "@contentlayer/generated": ["./.contentlayer/generated"]
    },
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".contentlayer/generated",
    ".contentlayer/generated/**/*.json"
  ],
  "exclude": ["node_modules"]
}
