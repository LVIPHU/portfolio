{
  "name": "portfolio",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "eslint .",
    "check-links": "node scripts/check-dead-links.mjs",
    "ci-check": "prettier --check . && turbo typecheck && turbo build && node scripts/check-dead-links.mjs",
    "dev:2025": "turbo dev --filter=web-2025",
    "dev:2026": "turbo dev --filter=web-2026",
    "prepare": "husky",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.10.3"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,css,md,mdx,json,yaml,yml}": "prettier --write"
  }
}
